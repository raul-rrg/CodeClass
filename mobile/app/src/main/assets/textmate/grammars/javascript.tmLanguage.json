{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "JavaScript",
  "scopeName": "source.js",
  "fileTypes": ["js", "mjs", "cjs"],
  "patterns": [
    { "include": "#line-comments" },
    { "include": "#block-comments" },
    { "include": "#template-strings" },
    { "include": "#strings" },
    { "include": "#regex" },
    { "include": "#function-def" },
    { "include": "#class-def" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#builtins" }
  ],
  "repository": {
    "line-comments": {
      "name": "comment.line.double-slash.js",
      "match": "\\/\\/.*$"
    },
    "block-comments": {
      "name": "comment.block.js",
      "begin": "\\/\\*",
      "end": "\\*\\/"
    },
    "template-strings": {
      "name": "string.template.js",
      "begin": "`",
      "end": "`"
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.js",
          "begin": "\"",
          "end": "\""
        },
        {
          "name": "string.quoted.single.js",
          "begin": "'",
          "end": "'"
        }
      ]
    },
    "regex": {
      "name": "string.regexp.js",
      "match": "\\/(?!\\/)[^\\n]*?\\/[gimsuy]*"
    },
    "function-def": {
      "patterns": [
        {
          "match": "\\b(function)\\s+([a-zA-Z_$][a-zA-Z0-9_$]*)\\b",
          "captures": {
            "1": { "name": "storage.type.function.js" },
            "2": { "name": "entity.name.function.js" }
          }
        },
        {
          "match": "\\b([a-zA-Z_$][a-zA-Z0-9_$]*)\\s*(?=\\(.*\\)\\s*=>)",
          "captures": {
            "1": { "name": "entity.name.function.js" }
          }
        },
        {
          "match": "\\b([a-zA-Z_$][a-zA-Z0-9_$]*)\\s*(?=:?\\s*(?:async\\s+)?(?:function|\\())",
          "captures": {
            "1": { "name": "entity.name.function.js" }
          }
        }
      ]
    },
    "class-def": {
      "match": "(?<=class )([a-zA-Z_$][a-zA-Z0-9_$]*)\\b",
      "captures": {
        "1": { "name": "entity.name.class.js" }
      }
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.js",
          "match": "\\b(if|else|for|while|do|switch|case|break|continue|return|try|catch|finally|throw|of|in)\\b"
        },
        {
          "name": "storage.type.js",
          "match": "\\b(var|let|const|function|class|import|export|from|default|extends|static|async|await|yield|new|delete|typeof|instanceof|void)\\b"
        },
        {
          "name": "keyword.operator.logical.js",
          "match": "\\b(and|or|not)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.js",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.js",
          "match": "\\b(null|undefined|NaN|Infinity)\\b"
        },
        {
          "name": "variable.language.this.js",
          "match": "\\bthis\\b"
        },
        {
          "name": "variable.language.self.js",
          "match": "\\bsuper\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.js",
          "match": "\\b\\d+\\.\\d*([eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.hex.js",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.integer.js",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "operators": {
      "name": "keyword.operator.js",
      "match": "\\+\\+|--|\\+|-|\\*|\\/|%|===|!==|==|!=|<=|>=|<|>|=|\\+=|-=|\\*=|\\/=|%=|&&|\\|\\||\\?\\?|!|&|\\||\\^|~|<<|>>|>>>|\\?\\."
    },
    "builtins": {
      "name": "support.function.builtin.js",
      "match": "\\b(console|Math|JSON|Object|Array|String|Number|Boolean|Promise|Symbol|Map|Set|WeakMap|WeakSet|Date|RegExp|Error|parseInt|parseFloat|isNaN|isFinite|decodeURI|encodeURI|setTimeout|setInterval|clearTimeout|clearInterval|fetch|require|module|exports|process|Buffer|__dirname|__filename)\\b"
    }
  }
}
